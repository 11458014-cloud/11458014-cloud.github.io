<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>英文單字測驗</title>
    <style>
      body{font-family: Arial, Helvetica, sans-serif; max-width:700px;margin:24px}
      .btn{padding:8px 12px;margin:6px}
      #feedback{margin-top:8px;font-weight:600}
    </style>
  </head>
  <body>
    <h2>英文單字測驗</h2>
    <div>
      題目數: <input id="num" type="number" value="5" min="1" style="width:60px"> 
      <button class="btn" onclick="startQuiz()">開始</button>
    </div>

    <div id="quiz" style="margin-top:20px;display:none">
      <div id="progress"></div>
      <div id="questionArea" style="margin-top:12px">
        <div id="questionText" style="font-size:18px;margin-bottom:8px"></div>
        <input id="answer" type="text" style="width:60%" autocomplete="off">
        <button class="btn" onclick="submitAnswer()">送出</button>
        <div id="feedback"></div>
      </div>
    </div>

    <div id="result" style="margin-top:18px;display:none"></div>

    <script>
      var questions = [];
      var current = 0;
      var score = 0;

      function startQuiz(){
        var n = parseInt(document.getElementById('num').value) || 5;
        document.getElementById('result').style.display = 'none';
        document.getElementById('quiz').style.display = 'block';
        document.getElementById('feedback').innerText = '';
        google.script.run.withSuccessHandler(function(res){
          questions = res || [];
          current = 0; score = 0;
          if (questions.length === 0){
            document.getElementById('questionText').innerText = '試算表內無題庫，請檢查試算表內容與 `SPREADSHEET_ID`';
            return;
          }
          showQuestion();
        }).getRandomQuestions(n);
      }

      function showQuestion(){
        if (current >= questions.length){
          showResult();
          return;
        }
        document.getElementById('progress').innerText = '第 ' + (current+1) + ' / ' + questions.length + ' 題';
        document.getElementById('questionText').innerText = '請翻譯: ' + questions[current].word;
        document.getElementById('answer').value = '';
        document.getElementById('feedback').innerText = '';
        document.getElementById('answer').focus();
      }

      function submitAnswer(){
        var ans = document.getElementById('answer').value;
        var word = questions[current].word;
        google.script.run.withSuccessHandler(function(isCorrect){
          if (isCorrect){
            score++;
            document.getElementById('feedback').innerText = '回答正確';
          } else {
            document.getElementById('feedback').innerText = '回答錯誤，正確答案: ' + questions[current].meaning;
          }
          current++;
          setTimeout(showQuestion, 900);
        }).checkAnswerByWord(word, ans);
      }

      function showResult(){
        document.getElementById('quiz').style.display = 'none';
        var s = '<h3>測驗完成</h3>';
        s += '<div>答對: ' + score + ' / ' + questions.length + '</div>';
        s += '<button class="btn" onclick="startQuiz()">再一次</button>';
        document.getElementById('result').innerHTML = s;
        document.getElementById('result').style.display = 'block';
      }
    </script>
  </body>
</html>

